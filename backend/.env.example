# PostgreSQL analytics
ANALYTICS_DB_DSN=postgresql+asyncpg://user:pass@localhost:5432/analytics
# Redis
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=default
# Telegram
TELEGRAM_BOT_TOKEN=bot_token
TELEGRAM_CHANNEL_ID=channel_id
TELEGRAM_COMMUNITY_ID=community_id
# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_PATH=/path/to/credentials.json
GOOGLE_SHEET_INTERVIEWS_ID=your_spreadsheet_id
# MongoDB
MONGODB_CONNECTION_STRING=mongodb://user:pass@localhost:27017/db
# Advertising APIs
ADVERTISING_API_GOOGLE=google_api_key
# Caching
CACHE_TTL_SECONDS=300
MARKETING_DAILY_BOT_API_URL=http://127.0.0.1:18081
MARKETING_DAILY_BOT_API_TOKEN=change_me
MARKETING_DAILY_ADMIN_IDS_CSV=542149705,6717031233
